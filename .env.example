POSTGRES_PORT=5432

BACKEND_PORT=8000
APP_NAME=Runna API
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8080"]

# Optional: enable Gemini AI summaries
GEMINI_API_KEY=

# Hazard pin auto-expiry in hours
PIN_EXPIRY_HOURS=24

# Optional password-reset email delivery
# Use "disabled" or "smtp". For local testing, point smtp at Mailpit (see docs/password-reset.md).
PASSWORD_RESET_EMAIL_BACKEND=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10
