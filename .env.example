POSTGRES_DB=runna
POSTGRES_USER=runna
POSTGRES_PASSWORD=runna_dev_password
POSTGRES_PORT=5432

BACKEND_PORT=8000
APP_NAME=Runna API
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://runna:runna_dev_password@db:5432/runna
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8080"]

# Optional: enable Gemini AI summaries
GEMINI_API_KEY=

# Default admin account (created on first startup)
ADMIN_EMAIL=admin@runna.local
ADMIN_PASSWORD=admin1234

# Hazard pin auto-expiry in hours
PIN_EXPIRY_HOURS=24
